{
  "name": "my-supapp",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:my-supapp": "node dist/my-supapp/server/server.mjs",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "lint:styles": "stylelint \"src/**/*.css\"",
    "lint:styles:fix": "stylelint \"src/**/*.css\" --fix",
    "format": "prettier --check \"src/**/*.{ts,html,css,json,md}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,html,css,json,md}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ],
    "*.html": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/cdk": "^21.2.4",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/ssr": "^21.0.0",
    "@genkit-ai/express": "^1.30.1",
    "@genkit-ai/google-genai": "^1.30.1",
    "@ng-icons/core": "^31.4.0",
    "@ng-icons/lucide": ">=32.0.0 <34.0.0",
    "@ngrx/signals": "^21.1.0",
    "@spartan-ng/brain": "^0.0.1-alpha.656",
    "@tailwindcss/postcss": "^4.2.2",
    "express": "^5.1.0",
    "genkit": "^1.30.1",
    "html2canvas": "^1.4.1",
    "ngx-quill": "^30.0.1",
    "postcss": "^8.5.8",
    "prismjs": "^1.30.0",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@spartan-ng/cli": "^0.0.1-alpha.656",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@types/prismjs": "^1.26.6",
    "@typescript-eslint/parser": "^8.57.2",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-rxjs-x": "^1.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^27.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  }
}
